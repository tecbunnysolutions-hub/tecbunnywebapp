# TecBunny monorepo environment template
# Copy to .env.local for local development or map these names into CI/CD secrets.
# Never commit real secret values.

# Runtime
NODE_ENV=development
VERCEL_ENV=development
NEXT_PUBLIC_APP_NAME=TecBunny Solutions
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_DOMAIN=localhost
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_MGMT_URL=http://localhost:3002
NEXT_PUBLIC_SUPERADMIN_URL=http://localhost:3003
NEXT_PUBLIC_WABA_URL=http://localhost:3004

# Supabase / PostgreSQL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SECRET_KEY=replace-with-supabase-service-role-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_DB_PASSWORD=replace-with-database-password
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
DIRECT_URL=postgresql://postgres:password@localhost:5432/postgres

# Supabase-compatible object storage
SUPABASE_BUCKET_NAME=tecbunny-assets
SUPABASE_S3_ACCESS_KEY=replace-with-storage-access-key
SUPABASE_S3_SECRET_KEY=replace-with-storage-secret-key
SUPABASE_S3_REGION=ap-south-1
SUPABASE_S3_URL=https://your-project.supabase.co/storage/v1/s3

# Security
SESSION_SECRET=replace-with-strong-random-secret
SUPERADMIN_SESSION_SECRET=replace-with-strong-random-secret
SUPERADMIN_USER_ID=superadmin@example.com
SUPERADMIN_PASSWORD=replace-with-strong-password
OTP_SECRET_PEPPER=replace-with-strong-random-pepper
TOTP_SECRET_ENCRYPTION_KEY=replace-with-strong-random-encryption-key
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=no-reply@example.com
SMTP_FROM_NAME=TecBunny Solutions
SUPPORT_TEAM_EMAIL=support@example.com
SALES_TEAM_EMAIL=sales@example.com

# WhatsApp / Infobip
INFOBIP_API_KEY=replace-with-infobip-api-key
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_HMAC_SECRET=replace-with-infobip-hmac-secret
INFOBIP_WHATSAPP_FROM=replace-with-whatsapp-sender-number
INFOBIP_WHATSAPP_TEMPLATE_LANGUAGE=en
INFOBIP_WHATSAPP_TEMPLATE_NAME=replace-with-template-name
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-webhook-verify-token
SYSTEM_NUMBER=replace-with-system-whatsapp-number

# Payments
PAYU_CLIENT_ID=replace-with-payu-client-id
PAYU_CLIENT_SECRET=replace-with-payu-client-secret
PAYU_ENVIRONMENT=test
PAYU_MERCHANT_KEY=replace-with-payu-merchant-key
PAYU_MERCHANT_SALT=replace-with-payu-merchant-salt

# AI / CRM / Cache
GEMINI_API_KEY=replace-with-gemini-api-key
HUBSPOT_ACCESS_TOKEN=replace-with-hubspot-access-token
REDIS_URL=redis://localhost:6379