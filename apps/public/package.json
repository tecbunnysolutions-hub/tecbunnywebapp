    "nodemailer": "^9.0.3",
    "p-limit": "^7.3.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-confetti": "^6.4.0",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
    "react-hot-toast": "2.6.0",
    "react-turnstile": "1.1.5",
    "sharp": "^0.35.3",
    "speakeasy": "2.0.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "3.6.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
