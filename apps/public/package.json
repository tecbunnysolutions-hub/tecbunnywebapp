{
  "name": "tecbunny-store",
  "version": "1.0.0",
  "description": "TecBunny E-commerce Platform with Order Management",
  "homepage": "https://tecbunny.com",
  "private": true,
  "scripts": {
    "dev": "next dev -p 9003",
    "build": "npx cross-env NODE_NO_WARNINGS=1 next build --webpack",
    "build:win": "npx cross-env NODE_NO_WARNINGS=1 next build --webpack",
    "build:css": "npx @tailwindcss/cli -i ./src/app/globals.css -o ./public/styles.css --minify",
    "build:prod": "npm run typecheck && npm run build:css && npm run build",
    "build:prod-full": "npm run typecheck && npm run lint:check && npm run build:css && npm run build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "clean": "rm -rf .next out",
    "clean:win": "rmdir /s /q .next out",
    "audit:fix": "npm audit fix --force",
    "deps:check": "npm outdated",
    "deps:update": "npm update --save",
    "test": "vitest",
    "lint:check": "echo 'Skipping lint:check - ESLint config not present'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "3.1090.0",
    "@google/genai": "^2.12.0",
    "@hookform/resolvers": "5.4.0",
    "@opentelemetry/api-logs": "^0.220.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "1.1.19",
    "@radix-ui/react-avatar": "1.2.2",
    "@radix-ui/react-checkbox": "1.3.7",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-popover": "1.1.19",
    "@radix-ui/react-radio-group": "1.4.3",
    "@radix-ui/react-scroll-area": "1.2.14",
    "@radix-ui/react-select": "2.3.3",
    "@radix-ui/react-separator": "1.1.11",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.3",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-toast": "1.2.19",
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-query": "^5.101.2",
    "@tecbunny/config": "*",
    "@tecbunny/core": "*",
    "@tecbunny/database": "*",
    "@tecbunny/rpc": "*",
    "@tecbunny/ui": "*",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.8",
    "cheerio": "^1.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "critters": "0.0.25",
    "date-fns": "^4.4.0",
    "fontkit": "^2.0.4",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "1.25.0",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
