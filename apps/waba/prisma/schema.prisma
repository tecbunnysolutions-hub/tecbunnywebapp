generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Conversation {
  id                         Int       @id @default(autoincrement())
  sender_number              String    @unique
  last_interaction_timestamp DateTime  @default(now())
  contact_name               String?
  status                     String    @default("NEW")
  tags                       String[]  @default([])
  notes                      String?
  ad_source                  String?
  assigned_to                String?
  department                 String    @default("UNASSIGNED")
  messages                   Message[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("AGENT")
  createdAt DateTime @default(now())
}

model Message {
  id              String       @id @default(uuid())
  message_id      String?      @unique
  sender_number   String
  direction       Direction
  message_content String
  timestamp       DateTime     @default(now())
  status          String       @default("DELIVERED")
  media_url       String?
  media_type      String?

  conversation    Conversation @relation(fields: [sender_number], references: [sender_number])
}

model FailedApiCall {
  id          Int      @id @default(autoincrement())
  payload     String
  error       String
  created_at  DateTime @default(now())
}

enum Direction {
  INBOUND
  OUTBOUND
}

model Template {
  id           String   @id @default(uuid())
  name         String   @unique
  language     String   @default("en")
  content      String
  status       String   @default("APPROVED")
  created_at   DateTime @default(now())
}

