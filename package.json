{
  "name": "tecbunny-monorepo",
  "packageManager": "npm@11.12.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prebuild": "tsx packages/core/src/environment-validator.ts",
    "build": "turbo run build --filter=./apps/* --filter=./packages/*",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "validate:ux-actions": "node scripts/validate-enterprise-actions.mjs",
    "validate:no-browser-modals": "node scripts/validate-no-browser-modals.mjs",
    "validate:accessibility-contract": "node scripts/validate-accessibility-contract.mjs",
    "validate:product-telemetry": "node scripts/validate-product-telemetry.mjs",
    "validate:performance-budgets": "node scripts/validate-performance-budgets.mjs",
    "validate:visual-baselines": "node scripts/validate-visual-baselines.mjs",
    "validate:launch-evidence": "node scripts/validate-launch-evidence.mjs",
    "validate:theme-contract": "node scripts/validate-theme-contract.mjs",
    "validate:launch-readiness": "node scripts/validate-launch-readiness.mjs",
    "validate:chrome-extension": "node scripts/validate-chrome-extension.mjs",
    "package:chrome-extension": "node scripts/package-chrome-extension.mjs",
    "audit:api": "node scripts/audit-api-surface.mjs",
    "validate:product-ux": "npm run validate:ux-actions && npm run validate:no-browser-modals && npm run validate:accessibility-contract && npm run validate:product-telemetry && npm run validate:performance-budgets && npm run validate:visual-baselines && npm run validate:launch-evidence && npm run validate:theme-contract && npm run validate:launch-readiness && npx tsc --noEmit --pretty false -p apps/public/tsconfig.json && npx tsc --noEmit --pretty false -p apps/mgmt/tsconfig.json && npx tsc --noEmit --pretty false -p apps/waba/tsconfig.json && npx tsc --noEmit --pretty false -p apps/superadmin/tsconfig.json",
    "clean": "turbo run clean",
    "prepare": "husky",
    "postinstall": "npm run db:generate",
    "db:generate": "npx prisma generate --schema=./packages/types/prisma/schema.prisma",
    "reset-db": "npm run reset-db --workspace=@tecbunny/infra",
    "test": "turbo run test"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsx": "^4.23.1",
    "turbo": "2.10.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "1.19.13"
    },
    "next": {
      "postcss": "8.5.19"
    }
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix"
    ]
  }
}
