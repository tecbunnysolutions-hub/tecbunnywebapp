{
  "name": "tecbunny-store",
  "version": "1.0.0",
  "description": "TecBunny E-commerce Platform with Order Management",
  "homepage": "https://tecbunny.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 9003",
    "build": "npx cross-env NODE_NO_WARNINGS=1 next build",
    "build:win": "npx cross-env NODE_NO_WARNINGS=1 next build",
    "build:css": "npx @tailwindcss/cli -i ./src/app/globals.css -o ./public/styles.css --minify",
    "build:prod": "npm run typecheck && npm run build:css && npm run build",
    "build:prod-full": "npm run typecheck && npm run lint:check && npm run build:css && npm run build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start",
    "lint": "npx cross-env NODE_NO_WARNINGS=1 next lint",
    "lint:fix": "next lint --fix",
    "lint:check": "next lint --quiet",
    "lint:src": "eslint src/ --ext .ts,.tsx,.js,.jsx",
    "lint:src:fix": "eslint src/ --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "clean": "rm -rf .next out",
    "clean:win": "rmdir /s /q .next out",
    "audit:fix": "npm audit fix --force",
    "deps:check": "npm outdated",
    "deps:update": "npm update --save",
    "test": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1024.0",
    "@aws-sdk/s3-request-presigner": "3.1024.0",
    "@hookform/resolvers": "5.2.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.10",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.7",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.7",
    "@radix-ui/react-slot": "1.2.3",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@supabase/ssr": "0.7.0",
    "@supabase/supabase-js": "2.57.0",
    "@vercel/analytics": "^2.0.1",
    "bullmq": "^5.77.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "critters": "0.0.25",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "fontkit": "2.0.4",
    "ioredis": "5.7.0",
    "lucide-react": "0.542.0",
    "nanoid": "^5.0.9",
    "next": "^16.2.6",
    "next-themes": "0.4.6",
    "nodemailer": "^8.0.4",
    "p-limit": "^7.3.0",
    "pdf-lib": "1.17.1",
    "pdfkit": "0.15.0",
    "qrcode": "1.5.4",
    "react": "19.2.6",
    "react-confetti": "^6.4.0",
    "react-dom": "19.2.6",
    "react-hook-form": "7.62.0",
    "react-hot-toast": "2.6.0",
    "react-turnstile": "1.1.4",
    "sharp": "^0.34.5",
    "speakeasy": "2.0.0",
    "tailwind-merge": "3.3.1",
    "tailwindcss-animate": "1.0.7",
    "zod": "4.1.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@next/eslint-plugin-next": "^16.2.6",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/cli": "4.1.13",
    "@tailwindcss/forms": "0.5.10",
    "@tailwindcss/postcss": "^4.1.0",
    "@tailwindcss/typography": "0.5.16",
    "@types/node": "^24.3.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "0.13.6",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/speakeasy": "2.0.10",
    "autoprefixer": "10.4.21",
    "cross-env": "10.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.5.14",
    "tailwindcss": "4.1.13",
    "typescript": "5.9.2",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.1.12",
    "@tailwindcss/oxide-linux-x64-musl": "^4.1.12",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.1.12",
    "lightningcss-linux-x64-gnu": "^1.30.1",
    "lightningcss-linux-x64-musl": "^1.30.1",
    "lightningcss-win32-x64-msvc": "^1.30.1"
  },
  "vitest": {
    "globals": true,
    "environment": "jsdom",
    "coverage": {
      "provider": "c8"
    }
  },
  "overrides": {
    "q": false,
    "@types/handlebars": false,
    "node-domexception": false,
    "@smithy/config-resolver": "^4.4.0",
    "esbuild": "0.28.0",
    "glob": "^11.0.0",
    "got": "11.8.6",
    "js-yaml": "^4.1.1",
    "magic-string": "0.30.19",
    "node-fetch": "^2.6.13",
    "postcss": "8.5.14",
    "path-to-regexp": "^8.3.1",
    "semver": "^7.7.2",
    "tar": ">=7.5.11",
    "undici": "^7.23.1",
    "ws": "^8.21.0",
    "@tootallnate/once": ">=3.0.1",
    "@xmldom/xmldom": ">=0.8.12",
    "eslint": {
      "ajv": "^6.14.0"
    },
    "@eslint/eslintrc": {
      "ajv": "^6.14.0",
      "minimatch": "^3.1.5"
    },
    "axios": ">=1.13.5",
    "brace-expansion": "5.0.6",
    "diff": "^4.0.4",
    "electron": ">=39.8.5",
    "flatted": "^3.4.2",
    "form-data": ">=4.0.4",
    "lodash": "^4.18.0",
    "minimatch": ">=3.1.4",
    "node-forge": ">=1.3.4",
    "picomatch": ">=2.3.2",
    "qs": ">=6.14.2",
    "tar-fs": ">=2.1.4",
    "tmp": ">=0.2.4",
    "vite": "$vite",
    "path-match": "^1.2.4",
    "dotprompt": {
      "@types/handlebars": false
    },
    "fetch-blob": {
      "node-domexception": false
    },
    "whatwg-url": "5.0.0",
    "@radix-ui/react-primitive": "2.1.3"
  },
  "resolutions": {
    "q": false,
    "@types/handlebars": false,
    "node-domexception": false
  },
  "engines": {
    "node": "20.x || 22.x || 24.x",
    "npm": ">=10.2.0"
  }
}
