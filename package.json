{
  "name": "tecbunny-monorepo",
  "packageManager": "npm@12.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prebuild": "tsx packages/core/src/environment-validator.ts",
    "build": "turbo run build --filter=./apps/* --filter=./packages/*",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "prepare": "husky",
    "postinstall": "npm run db:generate",
    "db:generate": "npx prisma generate --schema=./packages/types/prisma/schema.prisma",
    "reset-db": "npm run reset-db --workspace=@tecbunny/infra"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsx": "^4.23.1",
    "turbo": "2.10.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "1.19.13"
    },
    "next": {
      "postcss": "8.5.19"
    }
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix"
    ]
  }
}
