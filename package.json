{
  "name": "tecbunny-monorepo",
  "packageManager": "npm@10.8.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db-sync": "npx prisma migrate diff --from-schema-datamodel packages/infra/db/schema.prisma --to-schema-datasource packages/infra/db/schema.prisma --exit-code",
    "prebuild": "npm run db-sync && tsx packages/core/src/environment-validator.ts",
    "build": "turbo run build",
    "predev": "npm run db-sync",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-import-x": "^4.17.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "turbo": "latest"
  },
  "dependencies": {
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.42.0"
  }
}
