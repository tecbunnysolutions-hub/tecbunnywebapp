generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id                         Int       @id @default(autoincrement())
  sender_number              String    @unique
  last_interaction_timestamp DateTime  @default(now())
  contact_name               String?
  address                    String?
  pincode                    String?
  status                     String    @default("NEW")
  priority                   String    @default("NORMAL")
  tags                       String[]  @default([])
  notes                      String?
  ad_source                  String?
  assigned_to                String?
  department                 String    @default("UNASSIGNED")
  sla_breach_at              DateTime?
  messages                   Message[]
  orders                     Order[]

  assignedUser User? @relation("AssignedConversations", fields: [assigned_to], references: [id])

  @@map("Conversation")
}

model Organization {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")
  
  branches   Branch[]
  roles      Role[]
  users      User[]

  @@map("org_organizations")
}

model Branch {
  id              String       @id @default(uuid())
  organization_id String       @map("org_id")
  name            String
  location        String?
  created_at      DateTime     @default(now()) @map("created_at")
  updated_at      DateTime     @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  users           User[]

  @@map("org_branches")
}

model Role {
  id              String       @id @default(uuid())
  organization_id String?      @map("org_id")
  name            String
  description     String?
  is_system_role  Boolean      @default(false) @map("is_system")
  created_at      DateTime     @default(now()) @map("created_at")
  updated_at      DateTime     @updatedAt @map("updated_at")

  organization    Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  permissions     RolePermission[]
  users           User[]

  @@unique([organization_id, name])
  @@map("sys_roles")
}

model Permission {
  id          String   @id @default(uuid())
  module      String
  action      String
  description String?
  created_at  DateTime @default(now()) @map("created_at")

  roles       RolePermission[]

  @@unique([module, action])
  @@map("sys_permissions")
}

model RolePermission {
  role_id       String
  permission_id String

  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("sys_role_permissions")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String
  phone_number    String?
  
  organization_id String?
  branch_id       String?
  role_id         String?

  managed_pincodes Json? // PostgreSQL JSONB array of strings e.g., ["403512", "403513"]
  createdAt       DateTime @default(now())
  
  organization    Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  branch          Branch?       @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  role            Role?         @relation(fields: [role_id], references: [id], onDelete: SetNull)

  leads            Lead[]

  assigned_conversations Conversation[] @relation("AssignedConversations")
  assigned_tickets       Ticket[]       @relation("AssignedTickets")
  created_campaigns      Campaign[]

  @@map("sys_users_prisma")
}

enum DomainType {
  TECHNICAL_SERVICE
  PRODUCT_SALES
}

model Lead {
  id            String     @id @default(uuid())
  sender_number String?
  domain        DomainType
  sub_category  String // e.g., CCTV, COMPUTERS, NETWORKING, WEB_DEV, HARDWARE_SALES, OTHER
  pincode       String
  address       String?
  status        String     @default("NEW")
  assigned_to   String?
  created_at    DateTime   @default(now()) @map("created_at")
  updated_at    DateTime   @updatedAt @map("updated_at")

  assignedUser User? @relation(fields: [assigned_to], references: [id])

  @@map("sls_leads")
}

model Message {
  id              String    @id @default(uuid())
  message_id      String?   @unique
  sender_number   String
  direction       Direction
  message_content String
  timestamp       DateTime  @default(now())
  status          String    @default("DELIVERED")
  media_url       String?
  media_type      String?

  conversation Conversation @relation(fields: [sender_number], references: [sender_number])

  @@map("Message")
}

model FailedApiCall {
  id         Int      @id @default(autoincrement())
  payload    String
  error      String
  created_at DateTime @default(now())

  @@map("FailedApiCall")
}

enum Direction {
  INBOUND
  OUTBOUND
}

model Template {
  id         String   @id @default(uuid())
  name       String   @unique
  language   String   @default("en")
  content    String
  status     String   @default("APPROVED")
  created_at DateTime @default(now())
  campaigns  Campaign[]

  @@map("Template")
}

model PageContent {
  key              String   @id
  page_key         String?  @unique
  title            String?
  content          Json?
  data             Json?
  meta_description String?
  meta_keywords    String?
  status           String   @default("draft")
  is_active        Boolean  @default(false)
  updated_at       DateTime @default(now())
  created_at       DateTime @default(now())

  @@map("page_content")
}

model Ticket {
  id            String    @id @default(uuid())
  title         String
  description   String?
  status        String    @default("OPEN")
  priority      String    @default("NORMAL")
  department    String    @default("SUPPORT")
  assigned_to   String?
  sender_number String?
  created_at    DateTime  @default(now()) @map("created_at")
  updated_at    DateTime  @updatedAt @map("updated_at")
  sla_breach_at DateTime? @map("sla_breach_at")

  assignedUser User? @relation("AssignedTickets", fields: [assigned_to], references: [id])

  @@map("sup_tickets")
}

// ----------------------------------------
// E-Commerce Models
// ----------------------------------------
model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  category    String?
  imageUrl    String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id             String      @id @default(uuid())
  customer_phone String
  total_amount   Float
  status         String      @default("PENDING") // PENDING, PAID, DELIVERED, CANCELLED
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  items          OrderItem[]
  conversation   Conversation? @relation(fields: [customer_phone], references: [sender_number])

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  order_id   String
  product_id String
  quantity   Int
  price      Float

  order      Order   @relation(fields: [order_id], references: [id])
  product    Product @relation(fields: [product_id], references: [id])

  @@map("order_items")
}

// ----------------------------------------
// Marketing Hub Models
// ----------------------------------------
model Campaign {
  id          String   @id @default(uuid())
  name        String
  status      String   @default("DRAFT") // DRAFT, SCHEDULED, RUNNING, COMPLETED
  template_id String?
  schedule_at DateTime?
  created_by  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  
  targetAudience CampaignAudience?
  logs           CampaignLog[]

  creator     User?     @relation(fields: [created_by], references: [id])
  template    Template? @relation(fields: [template_id], references: [id])

  @@map("mkt_campaigns")
}

model CampaignAudience {
  id          String   @id @default(uuid())
  campaign_id String   @unique
  criteria    Json     // e.g. { "status": "LEAD", "last_active": "<90days" }
  size        Int      @default(0)

  campaign    Campaign @relation(fields: [campaign_id], references: [id])

  @@map("mkt_audience_members")
}

model CampaignLog {
  id          String   @id @default(uuid())
  campaign_id String
  phone       String
  status      String   @default("SENT") // SENT, DELIVERED, READ, REPLIED
  sent_at     DateTime @default(now())

  campaign    Campaign @relation(fields: [campaign_id], references: [id])

  @@map("mkt_campaign_analytics")
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  discount    Float
  type        String   @default("PERCENTAGE") // PERCENTAGE, FIXED
  expires_at  DateTime?
  usage_limit Int?
  usage_count Int      @default(0)
  created_at  DateTime @default(now())

  @@map("oms_coupons")
}
