generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Conversation {
  id                         Int       @id @default(autoincrement())
  sender_number              String    @unique
  last_interaction_timestamp DateTime  @default(now())
  contact_name               String?
  address                    String?
  pincode                    String?
  status                     String    @default("NEW")
  tags                       String[]  @default([])
  notes                      String?
  ad_source                  String?
  assigned_to                String?
  department                 String    @default("UNASSIGNED")
  messages                   Message[]
}

enum Role {
  SUPERADMIN
  SERVICE_MANAGER
  SALES_MANAGER
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String
  phone_number     String?
  role             Role     @default(SERVICE_MANAGER)
  managed_pincodes Json? // PostgreSQL JSONB array of strings e.g., ["403512", "403513"]
  createdAt        DateTime @default(now())
  leads            Lead[]
}

enum DomainType {
  TECHNICAL_SERVICE
  PRODUCT_SALES
}

model Lead {
  id            String     @id @default(uuid())
  sender_number String?
  domain        DomainType
  sub_category  String // e.g., CCTV, COMPUTERS, NETWORKING, WEB_DEV, HARDWARE_SALES, OTHER
  pincode       String
  address       String?
  status        String     @default("NEW")
  assigned_to   String?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  assignedUser User? @relation(fields: [assigned_to], references: [id])
}

model Message {
  id              String    @id @default(uuid())
  message_id      String?   @unique
  sender_number   String
  direction       Direction
  message_content String
  timestamp       DateTime  @default(now())
  status          String    @default("DELIVERED")
  media_url       String?
  media_type      String?

  conversation Conversation @relation(fields: [sender_number], references: [sender_number])
}

model FailedApiCall {
  id         Int      @id @default(autoincrement())
  payload    String
  error      String
  created_at DateTime @default(now())
}

enum Direction {
  INBOUND
  OUTBOUND
}

model Template {
  id         String   @id @default(uuid())
  name       String   @unique
  language   String   @default("en")
  content    String
  status     String   @default("APPROVED")
  created_at DateTime @default(now())
}

model PageContent {
  key              String   @id
  page_key         String?  @unique
  title            String?
  content          Json?
  data             Json?
  meta_description String?
  meta_keywords    String?
  status           String   @default("draft")
  is_active        Boolean  @default(false)
  updated_at       DateTime @default(now())
  created_at       DateTime @default(now())

  @@map("page_content")
}
