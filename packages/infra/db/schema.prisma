datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id         String   @id @db.Uuid
  full_name  String?
  phone      String?  @unique
  email      String?  @unique
  avatar_url String?
  role       String?  @default("user")
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  SalesAgent      SalesAgent[]
  ServiceTickets  ServiceTicket[] @relation("ServiceTicketCustomer")
  AssignedTickets ServiceTicket[] @relation("ServiceTicketAssignedTo")
  Quotes          Quote[]

  @@map("profiles")
}

model Customer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone      String?  @unique
  name       String?
  email      String?
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  Orders               Order[]
  CustomerInteractions CustomerInteraction[]

  @@map("customers")
}

model Product {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  handle           String   @unique
  title            String
  name             String?
  description      String?
  price            Decimal? @db.Decimal
  compare_at_price Decimal? @db.Decimal
  status           String?  @default("active")
  popularity       Int?     @default(0)
  rating           Decimal? @default(0) @db.Decimal
  review_count     Int?     @default(0)
  images           Json?
  category         String?
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @db.Timestamptz

  Inventory Inventory[]
  Purchases Purchase[]

  @@map("products")
}

model Tenant {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("tenants")
}

model WebhookEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id      String?   @unique
  event_type    String
  source        String
  payload       Json?
  processed     Boolean?  @default(false)
  status        String?
  error_message String?
  processed_at  DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @db.Timestamptz

  @@map("webhook_events")
}

model FreeInstallationSlot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  month           DateTime @unique @db.Date
  total_slots     Int      @default(10)
  remaining_slots Int      @default(10)
  confirmed_count Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamptz

  @@map("free_installation_slots")
}

model AutoOffer {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  description      String?
  discount_percent Decimal? @db.Decimal
  is_active        Boolean? @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz

  @@map("auto_offers")
}

model Setting {
  key        String   @id
  value      Json?
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  @@map("settings")
}

model PageContent {
  key        String   @id
  data       Json?
  updated_at DateTime @default(now()) @db.Timestamptz

  @@map("page_content")
}

model Faq {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question    String
  answer      String
  category    String?
  order_index Int?     @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz

  @@map("faqs")
}

model CustomSetupOffer {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  base_price  Decimal? @db.Decimal
  image_url   String?
  status      String?  @default("active")
  created_at  DateTime @default(now()) @db.Timestamptz

  @@map("custom_setup_offers")
}

model PublishedBlueprint {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  category    String?
  image_url   String?
  components  Json?
  config      Json?
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @db.Timestamptz

  @@map("published_blueprints")
}

model Service {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  icon        String?
  base_price  Decimal? @db.Decimal
  status      String?  @default("active")
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @db.Timestamptz

  @@map("services")
}

model ContactMessage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  email      String
  message    String
  status     String?  @default("Unread")
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  @@map("contact_messages")
}

model SecurityAuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  action     String
  resource   String?
  details    Json?
  ip_address String?
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("security_audit_log")
}

model Expense {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category     String
  amount       Decimal  @db.Decimal
  description  String?
  expense_date DateTime @db.Date
  created_at   DateTime @default(now()) @db.Timestamptz

  @@map("expenses")
}

model WabaUser {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String?
  email      String?  @unique
  role       String?  @default("agent")
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  @@map("User")
}

model Conversation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_number   String    @unique
  contact_name    String?
  active_flow     String?
  ai_active       Boolean?  @default(true)
  unread_count    Int?      @default(0)
  last_message_at DateTime? @default(now()) @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @default(now()) @db.Timestamptz

  Messages Message[]

  @@map("Conversation")
}

model Template {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  content    String
  language   String?  @default("en")
  status     String?  @default("approved")
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("Template")
}

model FailedApiCall {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  endpoint   String?
  payload    Json?
  error      String?
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("FailedApiCall")
}

model Order {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id               String    @unique
  customer_id            String?   @db.Uuid
  type                   String?
  total_amount           Decimal?  @db.Decimal
  payment_id             String?
  payment_method         String?
  payment_date           DateTime? @db.Timestamptz
  status                 String    @default("Pending")
  items                  Json?
  used_free_installation Boolean?  @default(false)
  created_at             DateTime  @default(now()) @db.Timestamptz
  updated_at             DateTime  @default(now()) @db.Timestamptz

  Customer              Customer?              @relation(fields: [customer_id], references: [id])
  Payments              Payment[]
  OrderCancellations    OrderCancellation[]
  SalesAgentCommissions SalesAgentCommission[]

  @@map("orders")
}

model SalesAgent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String?  @db.Uuid
  agent_code      String   @unique
  commission_rate Decimal? @default(0) @db.Decimal
  status          String?  @default("active")
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @db.Timestamptz

  Profile               Profile?               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  SalesAgentCommissions SalesAgentCommission[]

  @@map("sales_agents")
}

model ServiceTicket {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id       String?  @db.Uuid
  issue_description String
  status            String?  @default("Open")
  priority          String?  @default("Normal")
  assigned_to       String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @db.Timestamptz

  Customer   Profile? @relation("ServiceTicketCustomer", fields: [customer_id], references: [id])
  AssignedTo Profile? @relation("ServiceTicketAssignedTo", fields: [assigned_to], references: [id])

  @@map("service_tickets")
}

model Quote {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String?  @db.Uuid
  total_amount Decimal? @db.Decimal
  items        Json?
  status       String?  @default("Draft")
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @db.Timestamptz

  Profile Profile? @relation(fields: [user_id], references: [id])

  @@map("quotes")
}

model Inventory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String?  @db.Uuid
  sku        String?
  quantity   Int?     @default(0)
  location   String?
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  Product Product? @relation(fields: [product_id], references: [id])

  @@map("inventory")
}

model Purchase {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplier_name String?
  product_id    String?   @db.Uuid
  quantity      Int
  cost          Decimal   @db.Decimal
  purchase_date DateTime? @db.Date
  created_at    DateTime  @default(now()) @db.Timestamptz

  Product Product? @relation(fields: [product_id], references: [id])

  @@map("purchases")
}

model CustomerInteraction {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id      String?  @db.Uuid
  interaction_type String
  direction        String
  interaction_data Json?
  created_at       DateTime @default(now()) @db.Timestamptz

  Customer Customer? @relation(fields: [customer_id], references: [id])

  @@map("customer_interactions")
}

model Message {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String?   @db.Uuid
  message_id      String?   @unique
  sender_number   String
  receiver_number String
  content         String?
  type            String?   @default("text")
  status          String?   @default("sent")
  timestamp       DateTime? @default(now()) @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz

  Conversation Conversation? @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("Message")
}

model Payment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_id       String   @unique
  order_id         String?
  customer_phone   String?
  amount           Decimal  @db.Decimal
  currency         String?  @default("INR")
  payment_method   String?
  status           String
  gateway_response Json?
  source           String?
  metadata         Json?
  created_at       DateTime @default(now()) @db.Timestamptz

  Order Order? @relation(fields: [order_id], references: [order_id])

  @@map("payments")
}

model OrderCancellation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String?
  reason     String?
  status     String   @default("Pending")
  created_at DateTime @default(now()) @db.Timestamptz

  Order Order? @relation(fields: [order_id], references: [order_id])

  @@map("order_cancellations")
}

model SalesAgentCommission {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id   String?  @db.Uuid
  order_id   String?
  amount     Decimal  @db.Decimal
  status     String?  @default("Pending")
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  SalesAgent SalesAgent? @relation(fields: [agent_id], references: [id])
  Order      Order?      @relation(fields: [order_id], references: [order_id])

  @@map("sales_agent_commissions")
}
